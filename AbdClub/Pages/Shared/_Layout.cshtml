<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AbdClub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AbdClub.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">AbdClub</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                @inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
                @if (Env.IsDevelopment())
                {
                    <span class="navbar-text text-warning ms-auto">Development Mode!</span>
                }
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Index">Home</a>
                        </li>

                        @* {{!-- My Membership — only when logged in --}} *@
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Members/Dashboard">My Membership</a>
                            </li>
                        }

                        @* Officers dropdown — only for officers  *@
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Officer"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#"
                                   id="officersDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    Officers
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="officersDropdown">
                                    <li><a class="dropdown-item" asp-page="/Officers/Dashboard">Officers Dashboard</a></li>
                                    <li><a class="dropdown-item" asp-page="/Officers/Members">Members</a></li>
                                    <li><a class="dropdown-item" asp-page="/Officers/Meetings">Meetings</a></li>
                                    <li><a class="dropdown-item" asp-page="/Officers/Dances">Dances</a></li>
                                    <li><a class="dropdown-item" asp-page="/Officers/Files">Club Files</a></li>
                                </ul>
                            </li>
                        }

                        
                        @if (User.Identity?.IsAuthenticated == true &&
                                                    User.IsInRole("Officer") &&
                                                    User.FindFirst("OfficerRole")?.Value == "Tech Sergeant Chen")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Dev/Index">Dev</a>
                            </li>
                        }
                        @* Login — only when NOT logged in  *@
                        @if (User.Identity?.IsAuthenticated != true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Auth/Login">Login</a>
                            </li>
                        }

                        @* Join — only when NOT logged in  *@
                        @if (User.Identity?.IsAuthenticated != true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Membership">Join</a>
                            </li>
                        }
                    </ul>


                    @{
                        var displayName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                                         ?? User.Identity?.Name
                                         ?? "Member";
                    }
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Officer") &&
                            User.FindFirst("OfficerRole")?.Value == "Tech Sergeant Chen")
                        {
                            <span class="navbar-text ms-auto">Halo, @User.FindFirst("OfficerRole")?.Value!</span>
                        }
                        else
                        {
                            <span class="navbar-text ms-auto">Hello, @displayName!</span>
                        }
                        <!-- Logout button -->
                        <form method="post" asp-page="/Auth/Logout" class="ms-2 d-inline">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                Sign out
                            </button>
                        </form>
                    }

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Austin Ballroom Dancers - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
