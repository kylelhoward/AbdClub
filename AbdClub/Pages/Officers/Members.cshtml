@page
@model AbdClub.Pages.Officers.MembersModel
@{
    ViewData["Title"] = "Manage Members";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-0">Members</h1>
            <small class="text-muted">Manage club members and their statuses</small>
        </div>

        <div>
            <a class="btn btn-primary" href="/Officers/AddMember">Add Member</a>
        </div>
    </div>

    <nav class="mb-3" aria-label="Member filters">
        <ul class="nav nav-pills flex-wrap">
            <li class="nav-item">
                <a class="nav-link @(Model.Filter == "all" ? "active" : "")" href="?filter=all">All</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.Filter == "active" ? "active" : "")" href="?filter=active">Active</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.Filter == "expiring" ? "active" : "")" href="?filter=expiring">Expiring Soon</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.Filter == "expired" ? "active" : "")" href="?filter=expired">Expired</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.Filter == "officers" ? "active" : "")" href="?filter=officers">Officers</a>
            </li>
        </ul>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="text-muted">
            @Model.Members.Count member(s) found.
        </div>
        <div>
            <form class="d-flex" method="get" role="search" aria-label="Search members">
                <input name="q" value="@(Request.Query["q"])" class="form-control form-control-sm me-2" placeholder="Search name or email" />
                <button class="btn btn-outline-secondary btn-sm" type="submit">Search</button>
            </form>
        </div>
    </div>

    @if (!Model.Members.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <h5 class="card-title mb-1">No members found</h5>
                <p class="text-muted mb-3">No members match this filter or search.</p>
                <a class="btn btn-outline-primary" href="?filter=all">Show all members</a>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Contact</th>
                        <th scope="col">Joined</th>
                        <th scope="col">Expires</th>
                        <th scope="col">Role</th>
                        <th scope="col" class="text-center">Status</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model.Members)
                    {
                        var now = DateTime.UtcNow;
                        var expiry = member.ExpiryDate;
                        var isExpired = expiry.HasValue && expiry.Value < now;
                        var isExpiringSoon = expiry.HasValue && !isExpired && expiry.Value < now.AddDays(30);
                        <tr class="@(isExpired ? "table-danger" : "")">
                            <td>
                                <div class="fw-semibold">@member.FullName</div>
                                <div class="text-muted small">@member.Email</div>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(member.Phone))
                                {
                                    <div><a href="tel:@member.Phone" class="text-decoration-none">@member.Phone</a></div>
                                }
                                else
                                {
                                    <div class="text-muted">—</div>
                                }
                            </td>
                            <td>
                                <span class="small text-muted">@member.JoinDate.ToString("MMM d, yyyy")</span>
                            </td>
                            <td>
                                @if (expiry.HasValue)
                                {
                                    <span class="small">@expiry.Value.ToString("MMM d, yyyy")</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">Lifetime</span>
                                }
                            </td>
                            <td>
                                @if (member.IsOfficer)
                                {
                                    <span class="badge bg-primary">@member.OfficerRole</span>
                                }
                                else
                                {
                                    <span class="text-muted">Member</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (!member.IsActive)
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                                else if (isExpired)
                                {
                                    <span class="badge bg-danger">Expired</span>
                                }
                                else if (isExpiringSoon)
                                {
                                    <span class="badge bg-warning text-dark">Expiring soon</span>
                                }
                                else if (!expiry.HasValue)
                                {
                                    <span class="badge bg-info text-dark">No expiry</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group" role="group" aria-label="Actions for @member.FullName">
                                    <a class="btn btn-sm btn-outline-primary" href="/Officers/EditMember/@member.Id">Edit</a>
                                    <a class="btn btn-sm btn-outline-secondary" href="/Officers/ViewMember/@member.Id">View</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
