@page
@model AbdClub.Pages.MembershipModel
@{
    ViewData["Title"] = "Join Austin Ballroom Dancers";
}

<div class="membership-wrap">

    <h1>@(Model.IsRenewal ? "Renew Annual Membership" : "Annual Membership")</h1>
    <p class="lead">
        Join Austin Ballroom Dancers for one full year — just $50.
    </p>

    <ul class="perks">
        <li>Access to all monthly social dances</li>
        <li>Discounted workshop tickets</li>
        <li>Member newsletter and event reminders</li>
        <li>Voting rights at club meetings</li>
        <li>Priority event registration</li>
    </ul>

    @if (Model.PaymentCancelled)
    {
        <div class="alert alert-warning">
            Payment was cancelled — no charge was made.
            You can try again below.
        </div>
    }

    @if (Model.PaymentSuccess)
    {
        <div class="alert alert-success">
            <strong>Welcome to Austin Ballroom Dancers!</strong>
            <p>Your membership is now active. Here's how to log in:</p>
            <hr />

            <p><strong>Option 1 — Gmail users:</strong></p>
            <a asp-page="/Auth/Login" class="btn btn-outline-dark btn-sm">
                Sign in with Google
            </a>

            <p class="mt-3"><strong>Option 2 — All other email users:</strong></p>
            <p>
                Go to the <a asp-page="/Auth/Login">login page</a> and enter
                the email address you used to sign up. We'll send you a
                login link.
            </p>
        </div>
    }

    @if (!Model.PaymentSuccess)
    {
        <div class="membership-form">
            <h2>Your details</h2>
            @if (Model.IsRenewal)
            {
                <p>Your member details are prefilled below. Your sign-in email is locked to your account.</p>
            }
            else
            {
                <p>
                    Enter your information below. The email address you provide
                    is what you'll use to log in after joining.
                </p>
            }

            <form method="post">
                <div class="form-group">
                    <label for="fullName">Full name</label>
                    <input asp-for="FullName" type="text" id="fullName"
                           placeholder="Jane Smith" required
                           class="form-control" />
                </div>

                <div class="form-group">
                    <label for="email">
                        Email address
                        <small>(used to log in — Gmail or any email)</small>
                    </label>
                    <input asp-for="Email" type="email" id="email"
                           placeholder="jane@example.com" required
                           readonly="@Model.IsRenewal"
                           class="form-control" />
                </div>

                <div class="form-group">
                    <label for="phone">Phone <small>(optional)</small></label>
                    <input asp-for="Phone" type="tel" id="phone"
                           placeholder="512-555-0100"
                           class="form-control" />
                </div>

                <div class="price-summary">
                    <span>Annual Membership</span>
                    <span class="price">$50.00</span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg">
                    Pay $50 securely with Stripe
                </button>

                <p class="note">
                    You'll be taken to a secure Stripe payment page.
                    We never see your card details.
                </p>
                <p class="note">
                    <strong>Gmail users</strong> — log in with Google after joining.<br />
                    <strong>All other email users</strong> — use the magic link option on the login page.
                </p>
            </form>
        </div>
    }

</div>
